{
  "expo": {
    "name": "Mercatto",
    "slug": "mercatto",
    "version": "1.0.0",
    "description": "Marketplace móvil para conectar compradores con emprendimientos locales.",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "mercatto",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mercatto.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.mercatto.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FFA81A",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Mercatto usa tu ubicación para encontrar y confirmar la dirección de entrega."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Mercatto necesita acceso a tus fotos para agregar la portada de tu negocio."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#FFA81A",
          "dark": {
            "backgroundColor": "#FFA81A"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
